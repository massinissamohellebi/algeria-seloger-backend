# Application
APP_NAME=algeria-seloger-backend
ENVIRONMENT=development
DEBUG=true

# PostgreSQL (used by docker-compose)
POSTGRES_USER=algeria
POSTGRES_PASSWORD=algeria
POSTGRES_DB=algeria_seloger

# Database (async driver required)
# Use "db" hostname in Docker, "localhost" for local dev
DATABASE_URL=postgresql+asyncpg://algeria:algeria@db:5432/algeria_seloger

# JWT / Auth
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-please-use-a-long-random-value
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (JSON array format)
CORS_ORIGINS=["http://algeria-seloger.localhost"]

# Traefik hostnames (for docker-compose labels)
API_HOST=api.localhost
ADMINER_HOST=adminer.localhost
